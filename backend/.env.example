# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
APP_GOOGLE_FRONTEND_CALLBACK_URL=http://localhost:5173/auth/google/callback
PEER_SERVER_KEY=aegis-peer

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aegistalk
DB_USER=aegistalk
DB_PASSWORD=changeme_secure_123
DB_SSL=false

# JWT secret
JWT_SECRET=change-me-for-production

# Owner/admin user id (UUID). Only this user can access /api/admin and run system control commands.
OWNER_ID=replace-with-owner-uuid

# Admin panel second factor password (do not commit real production values).
ADMIN_PASSWORD=replace-with-admin-password

# CORS
CORS_ORIGIN=http://localhost:5173

# Email / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/callback/google
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AegisTalk <noreply@localhost>
RESEND_API_KEY=
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=20000
SMTP_IP_FAMILY=4

# Push notifications disabled by default
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
